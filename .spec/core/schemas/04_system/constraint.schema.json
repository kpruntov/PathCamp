{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Design & Implementation Constraint",
  "type": "object",
  "properties": {
    "id": { "type": "string", "pattern": "^CON-[0-9]{3}$" },
    "category": {
      "enum": ["Regulatory", "Technical", "Business", "Environmental"]
    },
    "statement": { "type": "string" },
    "rationale": { "type": "string", "description": "Why does this constraint exist?" },
    "trace_to": {
      "type": "object",
      "properties": {
        "stakeholders": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "required": ["id", "category", "statement"]
}
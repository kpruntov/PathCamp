{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Non-Functional Requirement",
  "type": "object",
  "properties": {
    "id": { "type": "string", "pattern": "^NFR-[0-9]{3}$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "category": {
      "enum": ["Performance", "Security", "Reliability", "Maintainability", "Usability"]
    },
    "trace_to": {
      "type": "object",
      "properties": {
        "user_requirements": { "type": "array", "items": { "type": "string" } },
        "stakeholders": { "type": "array", "items": { "type": "string" } },
        "business_rules": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "verification_plans": {
             "type": "array",
             "items": { "type": "string" },
             "description": "IDs of Verification Tasks (TASK-*) or Test Scenarios (SCN-*). MANDATORY."
        }
      },
      "minProperties": 1,
      "required": ["verification_plans"]
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["id", "title", "description", "category", "trace_to"]
}

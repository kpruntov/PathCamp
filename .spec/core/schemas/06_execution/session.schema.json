{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Execution Session Specification",
  "type": "object",
  "properties": {
    "id": { "type": "string", "pattern": "^SESS-[0-9]{4}$" },
    "task_id": { "type": "string", "description": "The Task this session is working on." },
    "status": { "enum": ["Active", "Paused", "Completed", "Failed"] },
    "environment": {
      "type": "object",
      "properties": {
        "git_branch": { "type": "string" },
        "dev_container_id": { "type": "string" },
        "last_commit_hash": { "type": "string" }
      }
    },
    "agent_metadata": {
      "type": "object",
      "properties": {
        "agent_name": { "type": "string" },
        "model_used": { "type": "string" },
        "session_start": { "type": "string", "format": "date-time" }
      }
    },
    "context_snapshot": {
      "type": "object",
      "description": "The state of the spec and code at the start of the session.",
      "properties": {
        "locked_files": { "type": "array", "items": { "type": "string" } },
        "relevant_requirements": { "type": "array", "items": { "type": "string" } }
      }
    },
    "transcript_path": { 
      "type": "string", 
      "description": "Path to the log of AI thoughts/actions for later resumption." 
    }
  },
  "required": ["id", "task_id", "status"]
}
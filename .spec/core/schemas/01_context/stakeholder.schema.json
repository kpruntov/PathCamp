{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "id": {
            "type": "string"
        },
        "name": {
            "type": "string"
        },
        "role": {
            "type": "string"
        },
        "influence": {
            "enum": [
                "Low",
                "Medium",
                "High",
                "Critical"
            ]
        },
        "interests": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": [
        "id",
        "name",
        "role"
    ]
}
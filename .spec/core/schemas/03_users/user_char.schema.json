{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "id": {
            "type": "string"
        },
        "user_type": {
            "type": "string"
        },
        "technical_expertise": {
            "enum": [
                "Novice",
                "Intermediate",
                "Expert"
            ]
        },
        "frequency_of_use": {
            "enum": [
                "Rare",
                "Occasional",
                "Frequent"
            ]
        },
        "known_constraints": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": [
        "id",
        "user_type",
        "technical_expertise"
    ]
}
{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Use Case (User Requirement)",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^UR-[0-9]{3}$"
        },
        "title": {
            "type": "string"
        },
        "primary_actor": {
            "type": "string"
        },
        "preconditions": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "postconditions": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "trigger": {
            "type": "string"
        },
        "main_scenario": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "step": {
                        "type": "integer"
                    },
                    "action": {
                        "type": "string"
                    }
                },
                "required": [
                    "step",
                    "action"
                ]
            }
        },
        "exceptions": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "step_ref": {
                        "type": "string"
                    },
                    "condition": {
                        "type": "string"
                    },
                    "action": {
                        "type": "string"
                    }
                },
                "required": [
                    "step_ref",
                    "condition",
                    "action"
                ]
            }
        },
        "trace_to": {
            "type": "object",
            "properties": {
                "business_goals": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "stakeholders": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "acceptance_criteria": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "minItems": 1,
            "description": "Conditions that must be met for the user to accept the requirement."
        },
        "priority": {
            "enum": [
                "High",
                "Medium",
                "Low"
            ]
        },
        "handshake_state": {
            "enum": [
                "Draft",
                "Agreed",
                "Modified"
            ],
            "default": "Draft"
        },
        "last_agreed_hash": {
            "type": "string"
        }
    },
    "required": [
        "id",
        "title",
        "primary_actor",
        "main_scenario",
        "acceptance_criteria"
    ]
}